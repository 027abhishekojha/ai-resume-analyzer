# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_TITLE="AI Resume Analyzer"
APP_PORT=8501
APP_DEBUG=False

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ─── Model Paths ──────────────────────────────────────────────────────────────
MODEL_PATH=models/trained/classifier.joblib
VECTORIZER_PATH=models/vectorizers/tfidf_vectorizer.joblib

# ─── Preprocessing ────────────────────────────────────────────────────────────
MAX_FEATURES=5000
NGRAM_MIN=1
NGRAM_MAX=2
MIN_DF=2

# ─── Inference ────────────────────────────────────────────────────────────────
# Similarity threshold above which a candidate is deemed "suitable"
SIMILARITY_THRESHOLD=0.65
CLASSIFICATION_THRESHOLD=0.60

# ─── Dataset ──────────────────────────────────────────────────────────────────
DATASET_PATH=datasets/raw/resume_dataset.csv
PROCESSED_DATASET_PATH=datasets/processed/processed_resumes.csv

# ─── Optional: External APIs (for future LLM integration) ─────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
